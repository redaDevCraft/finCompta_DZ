APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Global admin (Spatie role `admin`) — seeded on every `php artisan db:seed`
ADMIN_EMAIL=admin@fincompta.dz
ADMIN_PASSWORD=password
ADMIN_NAME=Administrateur

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Performance observability (Phase 0 baseline)
PERF_LOG_ENABLED=true
PERF_LOG_LEVEL=debug
PERF_LOG_DAYS=7
PERF_SLOW_QUERY_MS=50
PERF_SLOW_REQUEST_MS=400
# Résumé lecture seule des seuils ci-dessus : /settings/performance (owner / comptable).

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Jobs land on these queues (in priority order):
#   pdf     - invoice PDF rendering (fast, latency-sensitive)
#   reports - heavy report artifacts: bilan PDF, trial balance, exports
#             (CPU / memory heavy, can take minutes on large tenants)
#   ocr     - Tesseract OCR on uploaded documents (slow, CPU-heavy)
#   ai      - LLM extraction / column mapping (slow, network-bound)
#   default - catch-all
# Run a worker with:
#   php artisan queue:work --queue=pdf,default,reports,ai,ocr --tries=3 --timeout=600
# DO NOT set this to "sync" outside of one-off scripts — async dispatches then
# block the HTTP request and defeat the transactional-outbox discipline.
#
# The scheduler dispatches retention/reap tasks (see routes/console.php).
# Install this single cron entry — Laravel takes care of the rest:
#   * * * * * cd /path/to/app && php artisan schedule:run >> /dev/null 2>&1
# Scheduled maintenance currently runs:
#   - reports:sweep       daily at 03:10  (GC expired report artifacts)
#   - reports:reap-stuck  every 15 min    (mark crashed worker runs as failed)
QUEUE_CONNECTION=database

# The cache store also backs named RateLimiter buckets defined in
# App\Providers\RateLimiterServiceProvider. Current per-user+tenant
# limits (adjust in that provider, not here):
#   suggest           60 / min     (typeahead / address-book scrape)
#   reports-poll     240 / min     (Exports.jsx status polling)
#   reports-queue     10 / hour    (heavy Dompdf / export dispatches)
#                      3 / min     (burst cap)
#   reports-download  60 / min     (streamed artifact downloads)
# Using the `file` cache driver is NOT recommended at meaningful
# concurrency — switch to redis or database for rate-limiter fairness.
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── SaaS branding (exposed to frontend) ─────────────────────────────────
VITE_APP_BRAND="FinCompta DZ"
VITE_APP_TAGLINE="Comptabilité PME Algérie — SaaS cloud"

# ── Google OAuth (Socialite) ────────────────────────────────────────────
# Create an OAuth 2.0 Client (type: Web application) at
#   https://console.cloud.google.com/apis/credentials
#
# Authorized redirect URIs must match EXACTLY what Google receives (scheme, host, port, path).
# Local: add BOTH if you switch browsers/hosts, e.g.
#   http://127.0.0.1:8000/auth/google/callback
#   http://127.0.0.1:8000/oauth/google/callback   (alternate path — same handler)
#   http://localhost:8000/auth/google/callback
#
# Leave GOOGLE_REDIRECT_URI unset locally: config defaults to /auth/google/callback (resolved from the URL you open).
# Production: set GOOGLE_REDIRECT_URI=https://your-domain/auth/google/callback and add the same URI in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# ── Chargily Pay V2 (TEST MODE) ─────────────────────────────────────────
# Dashboard: https://pay.chargily.com/test/dashboard/developers-corner/api-keys
# Chargily Pay V2 — https://dev.chargily.com/pay-v2/api-keys.md
# CHARGILY_MODE must match the mode selected in the dashboard when you copy the keys (test vs live).
# CHARGILY_API_KEY = publishable key (test_pk_… / live_pk_…).
# CHARGILY_SECRET_KEY = secret key (test_sk_… / live_sk_…) — this value is sent as Authorization: Bearer (not the public key).
# Use TEST keys only until you go live.
CHARGILY_MODE=test
CHARGILY_BASE_URL_TEST=https://pay.chargily.net/test/api/v2
CHARGILY_BASE_URL_LIVE=https://pay.chargily.net/api/v2
CHARGILY_API_KEY=
CHARGILY_SECRET_KEY=
# Public HTTPS URL Chargily POSTs webhooks to (ngrok in local dev). Not a secret.
# Example: CHARGILY_WEBHOOK_URL=https://xxxx.ngrok-free.app/chargilypay/webhook
# CHARGILY_WEBHOOK_URL=
# Webhook HMAC: leave empty to use CHARGILY_SECRET_KEY. Do not put the webhook URL here — use CHARGILY_WEBHOOK_URL.
# CHARGILY_WEBHOOK_SECRET=
# Optional branding on the hosted checkout page
CHARGILY_LOCALE=fr

# ── SaaS billing ────────────────────────────────────────────────────────
# Duration of the free trial (in days) granted at company creation
SAAS_TRIAL_DAYS=3
# Grace period after subscription lapse before account is locked
SAAS_GRACE_DAYS=3
# Threshold (DZD) above which bon-de-commande requires double admin approval
SAAS_MANUAL_DOUBLE_APPROVAL_THRESHOLD=300000
# Auto-entrepreneur payee name + details shown on bon de commande
SAAS_PAYEE_NAME="FinCompta DZ"
SAAS_PAYEE_RC=""
SAAS_PAYEE_NIF=""
SAAS_PAYEE_NIS=""
SAAS_PAYEE_BANK_NAME=""
SAAS_PAYEE_BANK_RIB=""
SAAS_PAYEE_BANK_SWIFT=""
SAAS_PAYEE_EMAIL=""
SAAS_PAYEE_PHONE=""
SAAS_PAYEE_ADDRESS=""
# Admin email that receives bon-de-commande submissions
SAAS_ADMIN_EMAIL=""

# Local AI (Ollama)
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_LLM_MODEL=qwen2.5:3b
LOCAL_LLM_API_KEY=ollama

# OCR (Tesseract)
TESSERACT_PATH="C:\Program Files\Tesseract-OCR\tesseract.exe"
# Arabic-heavy invoices: try ara+fra+eng first; Latin-heavy use fra+ara+eng
TESSERACT_LANG=fra+ara+eng
TESSERACT_OEM=1
# 3 = auto layout (default). For dense Arabic tables try 11 (sparse) or 4 (single column).
TESSERACT_PSM=3
TESSERACT_TIMEOUT=90
# Second pass when primary OCR has little Arabic script (helps HT/TVA/TTC footers on DZ invoices).
TESSERACT_ARABIC_BOOST=false
TESSERACT_ARABIC_BOOST_LANG=ara+fra+eng
TESSERACT_ARABIC_BOOST_PSM=4
TESSERACT_ARABIC_BOOST_MIN_RATIO=0.06

# OCR (PDF support, optional)
PDFTOPPM_PATH=pdftoppm
PDF_OCR_DPI=300
OCRMYPDF_PATH=ocrmypdf
OCR_USE_OCRMYPDF=false

# OCR (upload + queue)
OCR_UPLOAD_MAX_KB=20480
OCR_QUEUE=ocr
OCR_JOB_TIMEOUT=180
OCR_JOB_TRIES=2
OCR_PARSER_INFER_KIND=true

# ── Dev: heavy data (local only; see DatabaseSeeder) ─────────────────────
